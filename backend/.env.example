# Kopiere diese Datei nach .env und trage echte Werte ein.
OPENAI_API_KEY=sk-...

# Optional: eigener OpenAI-kompatibler Endpoint
OPENAI_BASE_URL=https://api.openai.com

# Realtime Pipeline
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_INSTRUCTIONS=Du bist ein freundliches Team-Maskottchen. Antworte kurz, klar und hilfreich.

# Modulare Pipeline
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TEXT_MODEL=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=wav
OPENAI_MODULAR_INSTRUCTIONS=Du bist ein hilfreicher Meeting-Assistent. Antworte in maximal drei Saetzen.

# Audio / Socket Tuning
VOICE_INPUT_SAMPLE_RATE=24000
VOICE_INPUT_CHANNELS=1
VOICE_MAX_TURN_SECONDS=30
VOICE_IDLE_TIMEOUT_SECONDS=120
