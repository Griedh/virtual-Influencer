{
  "OpenAI": {
    "BaseUrl": "https://api.openai.com",
    "Realtime": {
      "Model": "gpt-realtime-2",
      "Voice": "alloy",
      "Instructions": "Du bist ein freundliches Team-Maskottchen. Antworte kurz, klar und hilfreich."
    },
    "Modular": {
      "TranscribeModel": "gpt-4o-transcribe",
      "TextModel": "",
      "TtsModel": "gpt-4o-mini-tts",
      "TtsVoice": "alloy",
      "TtsFormat": "wav",
      "Instructions": "Du bist ein hilfreicher Meeting-Assistent. Antworte in maximal drei Saetzen."
    }
  },
  "Voice": {
    "InputSampleRateHz": 24000,
    "InputChannels": 1,
    "MaxTurnAudioSeconds": 30,
    "IdleTimeoutSeconds": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
